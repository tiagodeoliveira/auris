# Auris — local dev secrets and config.
# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# `dotenvy` is loaded by the server binary, the `llm_smoke` example, and the
# integration test, so anything defined here is picked up automatically.

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. The repo's docker-compose.yml provisions a
# matching local instance — `just db-up` brings it up. For a hosted
# database, replace this URL; the schema is portable.
DATABASE_URL=postgres://auris:dev@localhost:5432/auris

# ─── Auth0 ────────────────────────────────────────────────────────────────────
# Server-side JWT validation against Auth0's JWKS. Required unless you
# set AURIS_AUTH_DISABLED=1 (which substitutes a synthetic
# user — handy for local dev / CI but obviously not for production).
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://auris.api

# Bypass Auth0 entirely. Server uses a synthetic dev user. Do not set
# in production.
# AURIS_AUTH_DISABLED=1

# HMAC-SHA256 secret for the device-pairing flow. Used to sign and
# verify the access tokens issued by `/pair/redeem` (PWA on EvenHub
# glasses). Required in Live mode; unused when AURIS_AUTH_DISABLED=1.
# Generate with: `openssl rand -hex 32`. Must be at least 32 bytes.
AURIS_JWT_HS256_SECRET=replace-with-openssl-rand-hex-32

# ─── Server ───────────────────────────────────────────────────────────────────
# Override blob storage location (transcript JSONL + moment screenshots
# + artifact bytes). Default: ./data
# AURIS_DATA_DIR=~/auris-data

# tracing-subscriber filter. Uncomment to see debug logs.
# RUST_LOG=auris_server=debug,info

# ─── LLM pool selection (chat + background) ──────────────────────────────────
# Two pools, configured independently. Each is REQUIRED — no fallback,
# no compatibility shim. Both pools must support vision + native PDF
# (the background pool reads PDFs via the artifact worker; the chat
# pool can be sent screenshots via the attachment path).
#
# Recommended defaults: chat = Anthropic Opus 4.7 (1M context, strong
# tool reasoning), background = Anthropic Haiku 4.5 (cheap, fast, native
# PDF). Both reach the same Anthropic account → one set of credentials,
# one billing line. Mix providers if you have a reason to.
#
# Each pool's provider: one of bedrock | openai | anthropic | gemini | xai.

AURIS_LLM_CHAT_PROVIDER=anthropic
AURIS_LLM_CHAT_MODEL_ID=claude-opus-4-7

AURIS_LLM_BACKGROUND_PROVIDER=anthropic
AURIS_LLM_BACKGROUND_MODEL_ID=claude-haiku-4-5-20251001

# Skip every LLM call (extraction, agent, summary, moment, artifact,
# wrap-up). Useful for offline dev.
# AURIS_LLM_DISABLED=1

# ─── OpenAI (when any pool has _PROVIDER=openai) ─────────────────────────────
OPENAI_API_KEY=sk-replace-me

# ─── Anthropic-direct (when any pool has _PROVIDER=anthropic) ────────────────
# ANTHROPIC_API_KEY=sk-ant-replace-me

# ─── Google Gemini (when any pool has _PROVIDER=gemini) ──────────────────────
# Required when either pool's _PROVIDER=gemini (Google AI Studio key).
# GEMINI_API_KEY=REPLACE-ME

# ─── xAI / Grok (when any pool has _PROVIDER=xai) ────────────────────────────
# Required when either pool's _PROVIDER=xai.
# XAI_API_KEY=REPLACE-ME

# ─── AWS Bedrock (when any pool has _PROVIDER=bedrock) ───────────────────────
# Use any standard AWS credentials chain. Examples:
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-west-2
# Bedrock-specific override (defaults to us-west-2). Global across
# pools — if you want per-pool regions, file a follow-up.
# AURIS_LLM_REGION=us-west-2

# ─── STT (when running with audio capture) ───────────────────────────────────
SONIOX_API_KEY=replace-me

# Override the Soniox STT model. Default: stt-rt-preview.
# AURIS_SONIOX_MODEL=stt-rt-preview

# Reconnect backoff for the Soniox WS session. Starts at BASE_MS,
# doubles on every consecutive failure, capped at MAX_S.
# AURIS_SONIOX_RECONNECT_BASE_MS=500
# AURIS_SONIOX_RECONNECT_MAX_S=30

# Idle-flush threshold. Buffered partials get emitted as a finalised
# turn after this many ms of no new tokens (end-of-utterance signal).
# AURIS_SONIOX_IDLE_FLUSH_MS=3000

# Override the STT provider. Defaults to `soniox` (the production path).
# Use `mock` for offline dev (no Soniox account / API key needed).
# AURIS_STT_PROVIDER=soniox

# Skip audio capture entirely (e.g., on Linux, or if you want a meeting
# without audio for any reason). When set, STT runs with audio_rx=None,
# so mock STT still emits canned chunks but Soniox produces nothing.
# AURIS_AUDIO_DISABLED=1

# Mock STT cadence (only meaningful with STT_PROVIDER=mock).
# AURIS_STT_MOCK_INTERVAL_MS=3000

# ─── Agent loop (single tool-calling LLM per active meeting) ──────────────────
# All optional; defaults work well in practice. Override only for tests
# or to tune cadence on slower / faster hardware. See ADR-0011.
# AGENT_TRIGGER_TOKENS=200          # new transcript tokens that trigger a fire
# AGENT_TRIGGER_SENTENCES=4         # new sentences that trigger a fire
# AGENT_TRIGGER_SILENCE_MS=4000     # silence window (no new chunks) that triggers a fire
# AGENT_TRIGGER_MAX_MS=30000        # hard cap between fires while a meeting is active
# AGENT_LOG_PROMPT=1                # log the full agent prompt on each fire (verbose)

# ─── Summary mode (single rolling 3-5 sentence meeting summary) ───────────────
# SUMMARY_TRIGGER_TOKENS=500        # tokens since last summary fire
# SUMMARY_BOOTSTRAP_TOKENS=100      # min tokens before the first summary fires
# SUMMARY_TRIGGER_MAX_MS=300000     # hard ceiling for summary refresh (5 min)

# ─── Moment summarizer ────────────────────────────────────────────────────────
# Window of transcript context (before + after the moment timestamp) the
# vision-LLM moment summarizer reads. Optional.
# AURIS_MOMENT_WINDOW_MS=60000
# AURIS_MOMENT_GRACE_MS=5000

# ─── Boot recovery ────────────────────────────────────────────────────────────
# Skip respawning Active meetings left in Postgres after a crash. Useful
# during local dev when you want a clean state per run.
# AURIS_SKIP_BOOT_RECOVERY=1

# ─── mnemo (memory layer) ────────────────────────────────────────────────────
# When both URL and API_KEY are set, the server pushes:
#   • one user-role turn per consolidated transcript sentence
#   • one assistant-role bundle (actions / highlights / open_questions /
#     summary) at meeting stop
#   • one assistant-role moment summary as each moment-summary worker finishes
# Leave unset to disable the integration entirely (no overhead).
# Values mirror ~/.mnemo/config.json.
# AURIS_MNEMO_URL=https://...execute-api...amazonaws.com/v1
# AURIS_MNEMO_API_KEY=replace-me
# Optional override; defaults to the host's gethostname().
# AURIS_MNEMO_WORKSTATION=tiago-laptop

# ─── Integration-test gate ────────────────────────────────────────────────────
# Set this to opt the env-gated integration test in (`just llm-integration`).
# RUN_LLM_INTEGRATION=1
