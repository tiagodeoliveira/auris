{
  "name": "auris",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "lint:rust": "cargo fmt --all -- --check && cargo clippy --workspace -- -D warnings",
    "fix:rust": "cargo fmt --all && cargo clippy --workspace --fix --allow-dirty --allow-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml}": "prettier --write"
  },
  "pnpm": {
    "patchedDependencies": {
      "expo-dev-menu@5.0.23": "patches/expo-dev-menu@5.0.23.patch"
    }
  }
}
