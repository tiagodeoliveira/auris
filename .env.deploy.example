# Production / single-VM deploy environment.
# Copy to `.env.deploy` on the host and fill in real values.
# `docker compose -f docker-compose.deploy.yml --env-file .env.deploy ...`

# ─── Image tag ───────────────────────────────────────────────────────────
# GHCR owner — your GitHub username or org. Lowercase per GHCR convention.
GHCR_OWNER=tiagodeoliveira

# Server image tag to pin. `latest` = always-newest-from-main (defeats
# rollback). Prefer a `vX.Y.Z` release tag or a `sha-<short>` from the
# CI publish run, so you know exactly what's running.
SERVER_TAG=latest

# Host port the server listens on (the container always binds :7331
# internally; this is the host-side mapping).
SERVER_PORT=7331

# ─── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=meeting_companion
POSTGRES_PASSWORD=__SET_ME__
POSTGRES_DB=meeting_companion

# ─── Auth0 ───────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://meeting-companion.api

# ─── LLM provider (default: bedrock) ─────────────────────────────────────
# One of: bedrock | anthropic | openai
MEETING_COMPANION_LLM_PROVIDER=bedrock

# Bedrock — leave blank to use the host's IAM role / instance profile.
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Anthropic — required when MEETING_COMPANION_LLM_PROVIDER=anthropic.
# Default model: claude-opus-4-7 (Opus 4.7, 1M context).
# ANTHROPIC_API_KEY=

# OpenAI — required when MEETING_COMPANION_LLM_PROVIDER=openai.
# Default model: gpt-4o.
# OPENAI_API_KEY=

# Override the model id (any provider):
# MEETING_COMPANION_LLM_MODEL_ID=claude-opus-4-7

# ─── STT (Soniox) ────────────────────────────────────────────────────────
# Required for live transcription. Leave unset to run without STT
# (audio captured but no transcript items emitted).
# SONIOX_API_KEY=
# MEETING_COMPANION_STT_PROVIDER=soniox          # soniox | mock
# MEETING_COMPANION_SONIOX_MODEL=stt-rt-preview
# MEETING_COMPANION_STT_MOCK_INTERVAL_MS=3000

# ─── Server tuning (optional — defaults are sane) ───────────────────────
# RUST_LOG=info
# MEETING_COMPANION_HEARTBEAT_MS=10000

# ─── Toggles (1 = enable, unset = off) ──────────────────────────────────
# MEETING_COMPANION_AUTH_DISABLED=          # bypasses Auth0 — DON'T set in prod
# MEETING_COMPANION_LLM_DISABLED=           # extraction + agent + summarizers no-op
# MEETING_COMPANION_AUDIO_DISABLED=         # skip audio capture entirely
# MEETING_COMPANION_SKIP_BOOT_RECOVERY=     # don't respawn crashed-active meetings
# AGENT_LOG_PROMPT=                         # log full agent prompt on each fire (verbose)

# ─── Agent loop (per ADR-0011 — defaults work well) ─────────────────────
# AGENT_TRIGGER_TOKENS=200                  # new transcript tokens that trigger a fire
# AGENT_TRIGGER_SENTENCES=4                 # new sentences that trigger a fire
# AGENT_TRIGGER_SILENCE_MS=4000             # silence window (ms) that triggers a fire
# AGENT_TRIGGER_MAX_MS=30000                # hard cap between fires (ms)

# ─── Summary mode ───────────────────────────────────────────────────────
# SUMMARY_TRIGGER_TOKENS=500                # tokens since last summary fire
# SUMMARY_BOOTSTRAP_TOKENS=100              # min tokens before first summary fires
# SUMMARY_TRIGGER_MAX_MS=300000             # hard ceiling for summary refresh (5 min)

# ─── Moment summarizer (vision-LLM context window) ──────────────────────
# MEETING_COMPANION_MOMENT_WINDOW_MS=60000  # transcript context window
# MEETING_COMPANION_MOMENT_GRACE_MS=5000    # grace period after the moment timestamp

# ─── mnemo memory backend ───────────────────────────────────────────────
# Optional. When set, the server pushes chat + moments to mnemo and
# recalls prior context at meeting start. Server-side names are all
# prefixed `MEETING_COMPANION_MNEMO_*`; missing any of URL / API_KEY
# silently disables the integration.
# MEETING_COMPANION_MNEMO_URL=https://mnemo.example.com
# MEETING_COMPANION_MNEMO_API_KEY=
# Optional workstation tag attached to every push (e.g. "tiagos-mac").
# MEETING_COMPANION_MNEMO_WORKSTATION=
