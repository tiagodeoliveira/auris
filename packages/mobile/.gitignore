node_modules/
.expo/
dist/
web-build/
*.log
.DS_Store

# Native projects — generated by `expo prebuild`. We use the managed
# workflow / EAS Build, so committing the ios/ and android/ trees
# would just be drift waiting to happen.
ios/
android/

# EAS local build outputs (`eas build --local`). Filenames are
# epoch-stamped (build-<unix>.ipa/.apk) — never useful in git.
build-*.ipa
build-*.apk

# Generated by Expo Router with `experiments.typedRoutes`.
expo-env.d.ts

.env
.env.local
# `.env.example` is committed — it documents the variable surface.
!.env.example
