{
  "expo": {
    "name": "Meeting Companion",
    "slug": "meeting-companion",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "meetingcompanion",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "sh.tiago.meetingcompanion",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "sh.tiago.meetingcompanion"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "eab5beef-bbaa-4517-9efc-498eb552cbb6"
      }
    },
    "owner": "tiagodeoliveira",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/eab5beef-bbaa-4517-9efc-498eb552cbb6"
    }
  }
}
