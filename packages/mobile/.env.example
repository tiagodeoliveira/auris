# Local development env. Copy to `.env.local` (gitignored) and fill
# in. Expo Router auto-loads `.env.local` at dev-server startup; for
# `eas build` / `eas update` from this machine, export the same
# values in your shell or pass via `--env`. CI passes them from the
# repo variables — see .github/workflows/README.md.

# Server WebSocket URL the app connects to.
EXPO_PUBLIC_SERVER_URL=ws://localhost:7331

# Auth0 — same tenant the PWA + Mac app talk to. Use the *Native*
# Auth0 application's client_id (not the SPA one), with the iOS
# bundle id and Android package added as allowed callbacks +
# `auris://` allowed for logout return.
EXPO_PUBLIC_AUTH0_DOMAIN=dev-jrva0wzk3qkdxcar.us.auth0.com
EXPO_PUBLIC_AUTH0_MOBILE_CLIENT_ID=
EXPO_PUBLIC_AUTH0_API_AUDIENCE=https://auris.api
