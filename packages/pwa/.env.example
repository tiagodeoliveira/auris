# WebSocket server URL — baked at build time, no longer a runtime
# setting. The Mac app does the same with `AppSettings.serverURLDefault`.
# Set per-deployment (dev vs hosted) before `vite build`.
VITE_SERVER_URL=ws://localhost:7331

# LAN-dev opt-in: when set, sync-whitelist appends this origin to
# app.json's network whitelist so the EvenHub companion lets the
# bundle load from the Vite dev server via QR. Unused for packed
# (.ehpk) builds.
# VITE_PWA_DEV_HOST=192.168.4.86

# Audio input device the EvenHub simulator (`pnpm run dev:sim`)
# opens for glasses-mic capture. Defaults to the MacBook built-in
# mic. List available devices with:
#     npx evenhub-simulator --list-audio-input-devices
# and copy the ID column (first column).
# AURIS_SIM_AID=coreaudio:AppleUSBAudioEngine:eMeet:eMeet M2:20080411:2

# Auth flows through the device-pairing endpoints on the server
# (/pair/code, /pair/redeem, /pair/refresh, /pair/devices,
# /pair/revoke). No third-party identity provider is invoked from
# this bundle — Auth0 lives on the mobile / Mac surfaces only.
