# WebSocket server URL — baked at build time, no longer a runtime
# setting. The Mac app does the same with `AppSettings.serverURLDefault`.
# Set per-deployment (dev vs hosted) before `vite build`.
VITE_SERVER_URL=ws://localhost:7331

# Auth0 config — copy to .env (gitignored). Build-time only; tokens
# never reach this file. The audience must match the API identifier
# you set in the Auth0 dashboard.
VITE_AUTH0_DOMAIN=dev-jrva0wzk3qkdxcar.us.auth0.com
VITE_AUTH0_PWA_CLIENT_ID=IPKnV1gX91eYYnX5Uc6142bQpnuA9n3G
VITE_AUTH0_API_AUDIENCE=https://auris.api
