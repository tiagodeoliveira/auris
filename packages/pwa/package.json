{
  "name": "@auris/pwa",
  "private": true,
  "version": "0.18.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sim": "concurrently -n vite,sim -c blue,green \"vite\" \"wait-on http://localhost:5173 && evenhub-simulator http://localhost:5173 --automation-port 9898 --aid \\\"${AURIS_SIM_AID:-coreaudio:BuiltInMicrophoneDevice}\\\"\"",
    "dev:qr": "evenhub qr --url http://$(ipconfig getifaddr en0):5173",
    "build": "vite build",
    "pack": "tsx scripts/sync-whitelist.ts && vite build && evenhub pack app.json dist -o auris.ehpk",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "@evenrealities/pretext": "^0.1.4",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "dompurify": "^3.4.11",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.12",
    "@evenrealities/evenhub-simulator": "^0.7.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "concurrently": "^8.2.0",
    "jsdom": "^24.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "wait-on": "^7.2.0"
  }
}
