# scripts/smoke/.env.test.example — copy to .env.test and fill in
# real values. .env.test is gitignored (see scripts/smoke/.gitignore).
#
# Same env-var surface as the production server (split-llm-pool spec
# §6.1), so swapping providers locally is just editing the two
# AURIS_LLM_{CHAT,BACKGROUND}_{PROVIDER,MODEL_ID} pairs and
# (un)commenting the matching credential block.


# ─── LLM pool config ──────────────────────────────────────────────────
# Two pools, configured independently. Both required; no fallback.
# Uncomment ONE chat block + ONE background block. Recommended:
# Anthropic on both pools (one key, one billing line, ~$0.05-0.20
# per smoke run on Opus 4.7 + Haiku 4.5).

# --- Anthropic (recommended default) ---
AURIS_LLM_CHAT_PROVIDER=anthropic
AURIS_LLM_CHAT_MODEL_ID=claude-opus-4-7
AURIS_LLM_BACKGROUND_PROVIDER=anthropic
AURIS_LLM_BACKGROUND_MODEL_ID=claude-haiku-4-5-20251001

# --- OpenAI ---
# AURIS_LLM_CHAT_PROVIDER=openai
# AURIS_LLM_CHAT_MODEL_ID=gpt-5.5
# AURIS_LLM_BACKGROUND_PROVIDER=openai
# AURIS_LLM_BACKGROUND_MODEL_ID=gpt-5.4-mini

# --- AWS Bedrock (Claude family via Bedrock) ---
# AURIS_LLM_CHAT_PROVIDER=bedrock
# AURIS_LLM_CHAT_MODEL_ID=us.anthropic.claude-opus-4-7-v1:0
# AURIS_LLM_BACKGROUND_PROVIDER=bedrock
# AURIS_LLM_BACKGROUND_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Gemini ---
# AURIS_LLM_CHAT_PROVIDER=gemini
# AURIS_LLM_CHAT_MODEL_ID=gemini-2.5-pro
# AURIS_LLM_BACKGROUND_PROVIDER=gemini
# AURIS_LLM_BACKGROUND_MODEL_ID=gemini-2.5-flash

# --- xAI / Grok ---
# Note: xAI has no native PDF support. If the background pool is xai
# and a meeting uploads a PDF artifact, the artifact summarizer fails
# at call time. Keep background on anthropic / bedrock / gemini if
# PDF artifacts are common.
# Also note: xAI uses dashes (NOT dots) in model version identifiers.
# `grok-4-1-fast` is the API id (not `grok-4.1-fast`).
# AURIS_LLM_CHAT_PROVIDER=xai
# AURIS_LLM_CHAT_MODEL_ID=grok-4.3
# AURIS_LLM_BACKGROUND_PROVIDER=xai
# AURIS_LLM_BACKGROUND_MODEL_ID=grok-4-1-fast


# ─── Provider credentials ─────────────────────────────────────────────
# Fill in credentials for whichever providers your two pools use.
# Leave the others commented out.

# Required when either pool's _PROVIDER=anthropic.
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Required when either pool's _PROVIDER=openai.
# OPENAI_API_KEY=sk-REPLACE-ME

# Required when either pool's _PROVIDER=bedrock. Uses the standard
# AWS credentials chain — set whichever combination you normally use.
# AWS_ACCESS_KEY_ID=REPLACE-ME
# AWS_SECRET_ACCESS_KEY=REPLACE-ME
# AWS_REGION=us-west-2
# AURIS_LLM_REGION=us-west-2     # Bedrock region (defaults to us-west-2)

# Required when either pool's _PROVIDER=gemini.
# GEMINI_API_KEY=REPLACE-ME

# Required when either pool's _PROVIDER=xai.
# XAI_API_KEY=REPLACE-ME


# ─── STT ──────────────────────────────────────────────────────────────
# Soniox is the production STT path; smoke exercises it end-to-end
# (no mocks) so a real key is required.

SONIOX_API_KEY=REPLACE-ME


# ─── DB ───────────────────────────────────────────────────────────────
# Disposable Postgres from scripts/smoke/docker-compose.yml.
# Compose-internal hostname `postgres` (NOT `localhost`) — the server
# container reaches postgres via the compose network. Leave as-is
# unless you've changed the compose file's postgres service name.

DATABASE_URL=postgres://auris:dev@postgres:5432/auris


# ─── Smoke shortcuts ──────────────────────────────────────────────────
# Synthetic dev user — no Auth0 / paired-device JWT setup required.
# Required for the smoke; do not unset.
AURIS_AUTH_DISABLED=1

# Disables tracing_subscriber's ANSI color/format escapes in stderr,
# which `docker logs -f` would otherwise propagate into server.log
# and break naive substring greps in the assertion code.
NO_COLOR=1
