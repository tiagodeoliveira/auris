# Sparkle EdDSA keys — never commit. Public key lives as a GitHub
# repo *variable* (SPARKLE_PUBLIC_KEY); private key as a *secret*.
# These patterns make sure a stray export inside the repo doesn't
# leak into a commit.
sparkle_priv.pem
sparkle_pub.txt
*.pem

# Editor
.vscode
.idea
*.swp
.DS_Store

# Env
.env
.env.local

# Server data dir (sqlite + future blobs). Default location used by
# `just server-run`; production / docker mount their own path via
# AURIS_DATA_DIR.
/data
**/data/server.db
**/data/server.db-journal
**/data/server.db-wal
**/data/server.db-shm
**/data/blobs/

.env
.env*
!.env.*example

# Deployment — Cloudflare Origin Certificate (bind-mounted into the
# caddy container) and the active Caddyfile (copied from
# Caddyfile.example, may be locally customized).
certs/
Caddyfile
